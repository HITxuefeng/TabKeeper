{
  "manifest_version": 3,
  "name": "TabKeeper",
  "version": "1.0.0",
  "description": "Smart tab manager with auto-grouping, drag-to-close, and fireworks",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "favicon",
    "bookmarks"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab/index.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
